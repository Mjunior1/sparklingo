rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/lessonProgress/{lessonId} {
      allow read, create, update: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/quizProgress/{quizId} {
      allow read, create, update: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/skillProgress/{skillId} {
      allow read, create, update: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/events/{eventId} {
      allow read, create: if isOwner(userId) || isAdmin();
    }

    match /userProgress/{userId} {
      allow read, create, update: if isOwner(userId) || isAdmin();
    }

    match /studySessions/{sessionId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update: if signedIn() &&
        (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /platform/runtime {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /lessons/{lessonId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /quizzes/{quizId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /quizQuestions/{questionId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /achievements/{achievementId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /generatedMedia/{assetId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
